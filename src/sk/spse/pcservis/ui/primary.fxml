<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.control.TreeItem?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: rgb(57, 62, 70);" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sk.spse.pcservis.ui.Controller">

    <!-- TOP TOOLBAR -->
    <top>
        <ToolBar style="-fx-background-color: #2c3e50;">
            <Button fx:id="pridat_komponent" onAction="#add_component_route" style="-fx-background-color: rgb(148, 137, 121);" text="Pridať komponent" />
        </ToolBar>
    </top>

    <!-- LEFT PANEL - INVENTÁR -->
    <left>
        <VBox prefHeight="685.0" prefWidth="337.0" spacing="10" style="-fx-background-color: rgb(57, 62, 70); -fx-padding: 15;">

            <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Inventár skladu" textFill="#dfd0b8" />

            <ComboBox fx:id="fitrovanie_skladu" promptText="Filtrovať kategóriu" style="-fx-background-color: rgb(148, 137, 121);">
                <items>
                    <FXCollections fx:factory="observableArrayList">
                        <String fx:value="CPU" />
                        <String fx:value="RAM" />
                        <String fx:value="SSD" />
                        <String fx:value="GPU" />
                        <String fx:value="MB" />
                        <String fx:value="ZDROJ" />
                        <String fx:value="CASE" />
                    </FXCollections>
                </items>
            </ComboBox>

            <TableView fx:id="inventar_table" style="-fx-background-color: rgb(223, 208, 184);" VBox.vgrow="ALWAYS">

                <columns>

                    <TableColumn prefWidth="140" text="Názov" />

                    <TableColumn prefWidth="100" text="Kategória" />

                    <TableColumn prefWidth="80" text="Cena (€)" />

                </columns>
            <columnResizePolicy>
               <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>

            </TableView>

        </VBox>
    </left>

    <!-- CENTER - TVORBA ZOSTAVY -->
    <center>

         <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minWidth="-Infinity" prefHeight="685.0" prefWidth="640.0" spacing="20" style="-fx-padding: 20; -fx-background-color: rgb(34, 40, 49);">

             <Label alignment="CENTER" contentDisplay="CENTER" maxWidth="1.7976931348623157E308" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Tvorba PC zostavy" textFill="#dfd0b8" />

                <!-- GRID PRE KOMPONENTY -->
             <GridPane hgap="15" vgap="15">

                    <Label text="CPU:" textFill="#dfd0b8" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                 <ComboBox fx:id="CPU_ComboBox" prefWidth="250" promptText="Vyber CPU" style="-fx-background-color: rgb(148, 137, 121);" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                    <Label text="RAM:" textFill="#dfd0b8" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                 <ComboBox fx:id="RAM_ComboBox" prefWidth="250" promptText="Vyber RAM" style="-fx-background-color: rgb(148, 137, 121);" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                    <Label text="GPU:" textFill="#dfd0b8" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                 <ComboBox fx:id="GPU_ComboBox" prefWidth="250" promptText="Vyber GPU" style="-fx-background-color: rgb(148, 137, 121);" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                    <Label text="SSD:" textFill="#dfd0b8" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                 <ComboBox fx:id="SSD_ComboBox" prefWidth="250" promptText="Vyber SSD" style="-fx-background-color: rgb(148, 137, 121);" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                    <Label text="MB:" textFill="#dfd0b8" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                 <ComboBox fx:id="MB_ComboBox" prefWidth="250" promptText="Vyber motherboard" style="-fx-background-color: rgb(148, 137, 121);" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                    <Label text="ZDROJ:" textFill="#dfd0b8" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                 <ComboBox fx:id="ZDROJ_ComboBox" prefWidth="250" promptText="Vyber zdroj" style="-fx-background-color: rgb(148, 137, 121);" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                    <Label text="CASE:" textFill="#dfd0b8" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                 <ComboBox fx:id="CASE_ComboBox" prefWidth="250" promptText="Vyber case" style="-fx-background-color: rgb(148, 137, 121);" GridPane.columnIndex="1" GridPane.rowIndex="6" />
            <columnConstraints>
               <ColumnConstraints />
               <ColumnConstraints />
            </columnConstraints>
            <rowConstraints>
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
            </rowConstraints>

                </GridPane>

             <!-- CELKOVÁ CENA -->
             <HBox spacing="10">
                 <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Celková cena:" textFill="#dfd0b8" />

                 <Label style="-fx-font-size: 18px; -fx-text-fill: rgb(148, 137, 121);" text="0 €" />
             </HBox>

             <!-- BUTTONY -->
             <HBox spacing="15">

                 <Button fx:id="uloz_zostavu_btn" prefWidth="180" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="Uložiť zostavu" />

                 <Button fx:id="predaj_zostavu_btn" prefWidth="180" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Predať zostavu" />

             </HBox>

             <!-- AUTO GENEROVANIE -->
             <TitledPane contentDisplay="CENTER" expanded="true" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="83.0" prefWidth="594.0" style="-fx-background-color: rgb(223, 208, 184); -fx-border-width: 0;" text="Automatické generovanie zostavy" textAlignment="CENTER">

                 <VBox alignment="CENTER" prefHeight="57.0" prefWidth="839.0" spacing="15" style="-fx-padding: 15; -fx-background-color: rgb(57, 62, 70);">

                     <HBox spacing="10">

                         <Label alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" text="Rozpočet (€):" textFill="#dfd0b8" />

                         <TextField fx:id="generuj_TextField" promptText="Napr. 1500" />

                         <Button fx:id="generuj_btn" onAction="#generuj" style="-fx-background-color: rgb(223, 208, 184); -fx-text-fill: rgb(34, 40, 49);" text="Generovať" />

                     </HBox>

                 </VBox>

             </TitledPane>

         </VBox>

    </center>

    <!-- RIGHT PANEL - ANALYTIKA -->
    <right>

        <VBox prefHeight="685.0" prefWidth="314.0" style="-fx-background-color: rgb(57, 62, 70); -fx-padding: 15;">

            <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Analytika" textFill="#dfd0b8" />

            <TabPane VBox.vgrow="ALWAYS">

                <!-- TAB ZOSTAVA -->
                <Tab closable="false" text="Výpis zostavy">

                    <VBox prefHeight="595.0" prefWidth="35.0" spacing="10" style="-fx-padding: 10;">

                        <TextArea prefHeight="300" style="-fx-background-color: rgb(223, 208, 184);" text="CPU: Ryzen 7&#10;RAM: 32GB&#10;GPU: RTX 4070&#10;Cena: 1450€" wrapText="true">
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding></TextArea>

                    </VBox>

                </Tab>

                <!-- TAB INVENTÁR -->
                <Tab closable="false" text="Inventár">
               <VBox alignment="TOP_CENTER">
                  <children>
      
                          <TreeView editable="true" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" style="-fx-background-color: rgb(223, 208, 184);">
      
                              <root>
                                  <TreeItem expanded="true" value="Komponenty">
      
                                      <children>
      
                                          <TreeItem value="CPU">
                                              <children>
                                                  <TreeItem value="Ryzen 5" />
                                                  <TreeItem value="Ryzen 7" />
                                              </children>
                                          </TreeItem>
      
                                          <TreeItem value="GPU">
                                              <children>
                                                  <TreeItem value="RTX 4060" />
                                                  <TreeItem value="RTX 4070" />
                                              </children>
                                          </TreeItem>
      
                                          <TreeItem value="RAM">
                                              <children>
                                                  <TreeItem value="16GB DDR5" />
                                                  <TreeItem value="32GB DDR5" />
                                              </children>
                                          </TreeItem>
      
                                      </children>
      
                                  </TreeItem>
                              </root>
                        <padding>
                           <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                        </padding>
                        <VBox.margin>
                           <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                        </VBox.margin>
      
                          </TreeView>
                  </children>
               </VBox>

                </Tab>

            </TabPane>

        </VBox>

    </right>

</BorderPane>
