<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.BorderPane?>
<?import java.lang.String?>
<?import javafx.collections.FXCollections?>

<BorderPane
    prefWidth="700.0"
    prefHeight="620.0"
    style="-fx-background-color: rgb(34, 40, 49);"
    stylesheets="@styles.css"
    xmlns="http://javafx.com/javafx/25"
    xmlns:fx="http://javafx.com/fxml/1">

    <!-- NADPIS HORE -->
    <top>
        <VBox style="-fx-background-color: rgb(57, 62, 70); -fx-padding: 20 25 15 25;" spacing="5">
            <Label
                text="Vytvoriť zostavu"
                textFill="#dfd0b8"
                style="-fx-font-size: 22px; -fx-font-weight: bold;" />
            <Label
                text="Vyber komponenty a ulož novú PC zostavu"
                textFill="rgb(148, 137, 121)"
                style="-fx-font-size: 12px;" />
            <Separator style="-fx-background-color: rgb(148, 137, 121);" />
        </VBox>
    </top>

    <!-- STRED - FORMULÁR + NÁHĽAD -->
    <center>
        <HBox spacing="0">

            <!-- ĽAVÁ ČASŤ - VÝBER KOMPONENTOV -->
            <VBox prefWidth="340.0" spacing="14"
                  style="-fx-padding: 20; -fx-background-color: rgb(34, 40, 49);">

                <Label text="Komponenty zostavy" textFill="#dfd0b8"
                       style="-fx-font-size: 15px; -fx-font-weight: bold;" />

                <GridPane hgap="12" vgap="12">
                    <columnConstraints>
                        <ColumnConstraints minWidth="70" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="32" />
                        <RowConstraints minHeight="32" />
                        <RowConstraints minHeight="32" />
                        <RowConstraints minHeight="32" />
                        <RowConstraints minHeight="32" />
                        <RowConstraints minHeight="32" />
                        <RowConstraints minHeight="32" />
                    </rowConstraints>

                    <Label text="CPU:" textFill="#dfd0b8"
                           GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <ComboBox prefWidth="220" promptText="Vyber CPU"
                              style="-fx-background-color: rgb(148, 137, 121);"
                              GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="Ryzen 5 5600X" />
                                <String fx:value="Ryzen 7 5800X" />
                                <String fx:value="Intel i5-13600K" />
                                <String fx:value="Intel i7-13700K" />
                            </FXCollections>
                        </items>
                    </ComboBox>

                    <Label text="RAM:" textFill="#dfd0b8"
                           GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <ComboBox prefWidth="220" promptText="Vyber RAM"
                              style="-fx-background-color: rgb(148, 137, 121);"
                              GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="16GB DDR5" />
                                <String fx:value="32GB DDR5" />
                                <String fx:value="64GB DDR5" />
                            </FXCollections>
                        </items>
                    </ComboBox>

                    <Label text="GPU:" textFill="#dfd0b8"
                           GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <ComboBox prefWidth="220" promptText="Vyber GPU"
                              style="-fx-background-color: rgb(148, 137, 121);"
                              GridPane.columnIndex="1" GridPane.rowIndex="2">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="RTX 4060" />
                                <String fx:value="RTX 4070" />
                                <String fx:value="RTX 4080" />
                                <String fx:value="RX 7800 XT" />
                            </FXCollections>
                        </items>
                    </ComboBox>

                    <Label text="SSD:" textFill="#dfd0b8"
                           GridPane.columnIndex="0" GridPane.rowIndex="3" />
                    <ComboBox prefWidth="220" promptText="Vyber SSD"
                              style="-fx-background-color: rgb(148, 137, 121);"
                              GridPane.columnIndex="1" GridPane.rowIndex="3">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="500GB NVMe" />
                                <String fx:value="1TB NVMe" />
                                <String fx:value="2TB NVMe" />
                            </FXCollections>
                        </items>
                    </ComboBox>

                    <Label text="MB:" textFill="#dfd0b8"
                           GridPane.columnIndex="0" GridPane.rowIndex="4" />
                    <ComboBox prefWidth="220" promptText="Vyber motherboard"
                              style="-fx-background-color: rgb(148, 137, 121);"
                              GridPane.columnIndex="1" GridPane.rowIndex="4">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="ASUS B550-F" />
                                <String fx:value="MSI MAG B650" />
                                <String fx:value="Gigabyte Z790" />
                            </FXCollections>
                        </items>
                    </ComboBox>

                    <Label text="ZDROJ:" textFill="#dfd0b8"
                           GridPane.columnIndex="0" GridPane.rowIndex="5" />
                    <ComboBox prefWidth="220" promptText="Vyber zdroj"
                              style="-fx-background-color: rgb(148, 137, 121);"
                              GridPane.columnIndex="1" GridPane.rowIndex="5">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="550W 80+ Gold" />
                                <String fx:value="650W 80+ Gold" />
                                <String fx:value="850W 80+ Platinum" />
                            </FXCollections>
                        </items>
                    </ComboBox>

                    <Label text="CASE:" textFill="#dfd0b8"
                           GridPane.columnIndex="0" GridPane.rowIndex="6" />
                    <ComboBox prefWidth="220" promptText="Vyber case"
                              style="-fx-background-color: rgb(148, 137, 121);"
                              GridPane.columnIndex="1" GridPane.rowIndex="6">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="Fractal Define 7" />
                                <String fx:value="NZXT H510" />
                                <String fx:value="Corsair 4000D" />
                            </FXCollections>
                        </items>
                    </ComboBox>

                </GridPane>

            </VBox>

            <!-- ODDELOVAČ -->
            <Separator orientation="VERTICAL"
                       style="-fx-background-color: rgb(57, 62, 70);" />

            <!-- PRAVÁ ČASŤ - NÁHĽAD ZOSTAVY -->
            <VBox prefWidth="340.0" spacing="14"
                  style="-fx-padding: 20; -fx-background-color: rgb(34, 40, 49);">

                <Label text="Náhľad zostavy" textFill="#dfd0b8"
                       style="-fx-font-size: 15px; -fx-font-weight: bold;" />

                <TableView prefHeight="320.0"
                           style="-fx-background-color: rgb(223, 208, 184);"
                           VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn text="Komponent" prefWidth="110" />
                        <TableColumn text="Model" prefWidth="150" />
                        <TableColumn text="Cena (€)" prefWidth="70" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <!-- NÁZOV ZOSTAVY -->
                <VBox spacing="6">
                    <Label text="Názov zostavy:" textFill="rgb(148, 137, 121)"
                           style="-fx-font-size: 12px;" />
                    <TextField promptText="Napr. Gaming zostava 2025" />
                </VBox>

                <!-- CELKOVÁ CENA -->
                <HBox spacing="10" alignment="CENTER_LEFT"
                      style="-fx-background-color: rgb(57, 62, 70); -fx-padding: 10; -fx-background-radius: 4;">
                    <Label text="Celková cena:" textFill="#dfd0b8"
                           style="-fx-font-size: 14px; -fx-font-weight: bold;" />
                    <Label text="0 €"
                           style="-fx-font-size: 14px; -fx-text-fill: rgb(148, 137, 121); -fx-font-weight: bold;" />
                </HBox>

            </VBox>

        </HBox>
    </center>

    <!-- DOLNÉ TLAČIDLÁ -->
    <bottom>
        <VBox style="-fx-background-color: rgb(57, 62, 70); -fx-padding: 15 25 15 25;" spacing="0">
            <Separator style="-fx-background-color: rgb(148, 137, 121);" />
            <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 12 0 0 0;">
                <Button prefWidth="160"
                        text="Uložiť zostavu"
                        style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;" />
                <Button prefWidth="160"
                        text="Vymazať výber"
                        style="-fx-background-color: rgb(148, 137, 121); -fx-text-fill: rgb(34, 40, 49); -fx-font-weight: bold;" />
                <Button prefWidth="160"
                        text="Zrušiť"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;" />
            </HBox>
        </VBox>
    </bottom>

</BorderPane>
